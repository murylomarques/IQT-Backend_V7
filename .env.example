APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

# Banco Melhoria Continua (views MCP)
MCP_DB_HOST=127.0.0.1
MCP_DB_PORT=3306
MCP_DB_DATABASE=db_Melhoria_continua_operacoes
MCP_DB_USERNAME=root
MCP_DB_PASSWORD=

# Banco isolado da API Moavi
MOAVI_DB_HOST=127.0.0.1
MOAVI_DB_PORT=3306
MOAVI_DB_DATABASE=dw_moavi
MOAVI_DB_USERNAME=root
MOAVI_DB_PASSWORD=
MOAVI_SOURCE_CONNECTION=melhoria_continua
MOAVI_SOURCE_TABLE=agendamentos_geovane
MOAVI_FILTER_MICRO_TERRITORIO=praiagrande
MOAVI_FILTER_EMPRESA_TECNICO=desktop
MOAVI_COMPANY_CNPJ=08.170.849/0053-46
MOAVI_TIMEZONE=America/Sao_Paulo
MOAVI_TOKEN_TTL_MINUTES=60
MOAVI_SYNC_KEY_TTL_DAYS=7
MOAVI_PAGE_SIZE_DEFAULT=500
MOAVI_PAGE_SIZE_MAX=2000

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
